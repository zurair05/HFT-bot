{
  "system": {
    "name": "MT5 HFT Trading Bot",
    "version": "1.0.0",
    "mode": "production",
    "environment": "vps",
    "timezone": "UTC",
    "log_level": "INFO"
  },
  "mt5": {
    "account": 0,
    "password": "",
    "server": "",
